<Window x:Class="WpfBasicApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfBasicApp"
        mc:Ignorable="d"
        Title="캐릭터 생성기" Height="600" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto" MinHeight="300"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="이름: " HorizontalAlignment="Center" VerticalAlignment="Center"></Label>
            <Label Grid.Row="1" Grid.Column="0" Content="직업: " HorizontalAlignment="Center" VerticalAlignment="Center"></Label>
            <Label Grid.Row="2" Grid.Column="0" Content="레벨: " HorizontalAlignment="Center" VerticalAlignment="Center"></Label>

            <TextBox x:Name="tbxCharName"
                     Grid.Row="0" Grid.Column="1"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" 
                     Width="150" Height="30"
                     Text="캐릭터 이름을 입력하세요."
                     Foreground="Gray"
                     GotFocus="tbxCharName_GotFocus"
                     LostFocus="tbxCharName_LostFocus"></TextBox>

            <ComboBox x:Name="cmbbxCharClass" Grid.Row="1" Grid.Column="1" Width="150" Height="30" SelectionChanged="cmbbxCharClass_SelectionChanged">
                <ComboBoxItem Content="전사"></ComboBoxItem>
                <ComboBoxItem Content="마법사"></ComboBoxItem>
            </ComboBox>

            <TextBox x:Name="tbxCharLevel" Grid.Row="2" Grid.Column="1"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Width="150" Height="30"
                     PreviewKeyDown="tbxCharLevel_PreviewKeyDown"
                     KeyDown="tbxCharLevel_KeyDown"></TextBox>

            <Label Content="HP: " Grid.Row="3" Grid.Column="0" HorizontalAlignment="Center"></Label>
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Hp}"></TextBox>
            <Label Content="MP: " Grid.Row="4" Grid.Column="0" HorizontalAlignment="Center"></Label>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Mp}"></TextBox>
        </Grid>

        <CheckBox x:Name="chkImportant" Grid.Row="1" Content="중요 캐릭터" HorizontalAlignment="Center" IsChecked="False" Margin="0,5,0,5"></CheckBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,5" >
            <Label x:Name="lblCharClass" Width="Auto" Content=""></Label>
            <Button x:Name="btnCreate" Content="생성" Margin="5,0,10,0" Padding="10,5" ></Button>
            <Button x:Name="btnDelete" Content="삭제"  Margin="10,0,5,0" Padding="10,5" Click="btnDelete_Click"></Button>
        </StackPanel>

        <StackPanel x:Name="stackPnlCharlst" Grid.Row="3" MouseDown="stackPnlCharlst_MouseDown" Background="Aqua">
            <Label x:Name="lblSender" Margin="5"></Label>
            <Label x:Name="lblSource" Margin="5"></Label>
            <ListBox x:Name="lstbxChars" Margin="10,10,10,10" >
            </ListBox>
        </StackPanel>
    </Grid>
</Window>
