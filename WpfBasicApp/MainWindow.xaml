<Window x:Class="WpfBasicApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfBasicApp"
        mc:Ignorable="d"
        Title="캐릭터 생성기" Height="600" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            
            <Label Grid.Row="0" Grid.Column="0" Content="이름: " HorizontalAlignment="Center" VerticalAlignment="Center"></Label>
            <Label Grid.Row="1" Grid.Column="0" Content="직업: " HorizontalAlignment="Center" VerticalAlignment="Center"></Label>
            <Label Grid.Row="2" Grid.Column="0" Content="레벨: " HorizontalAlignment="Center" VerticalAlignment="Center"></Label>

            <TextBox x:Name="tbxCharName" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="150" Height="30"></TextBox>
            <ComboBox x:Name="cmbbxCharClass" Grid.Row="1" Grid.Column="1" Width="150" Height="30">
                <ComboBoxItem Content="전사" IsSelected="True"></ComboBoxItem>
                <ComboBoxItem Content="마법사"></ComboBoxItem>

            </ComboBox>
            <TextBox x:Name="tbxCharLevel" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="150" Height="30"></TextBox>
        </Grid>

        <CheckBox x:Name="chkImportant" Grid.Row="1" Content="중요 캐릭터" HorizontalAlignment="Center" IsChecked="False" Margin="0,5"></CheckBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5" >
            <Button x:Name="btnCreate" Content="생성" Margin="5,0,10,0" Padding="10,5" Click="btnCreate_Click"></Button>
            <Button x:Name="btnDelete" Content="삭제"  Margin="10,0,5,0" Padding="10,5" Click="btnDelete_Click"></Button>
        </StackPanel>

        <ListBox x:Name="lstbxChars" Grid.Row="3" Margin="10">
        </ListBox>
    </Grid>
</Window>
