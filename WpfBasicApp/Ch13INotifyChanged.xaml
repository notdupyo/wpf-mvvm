<Window x:Class="WpfBasicApp.Ch13INotifyChanged"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfBasicApp"
        mc:Ignorable="d"
        Title="Ch13INotifyChanged" Height="800" Width="450">
    <StackPanel>
        <Label Content="캐릭터 목록: " Margin="10" />

        <ListBox x:Name="lstbx"
                 ItemsSource="{Binding ch13Characters}"
                 DisplayMemberPath="Name"
                 SelectedItem="{Binding SelectedChar}"
                 Margin="10">
        </ListBox>

        <Button Content="캐릭터 추가" Margin="10" Click="btnAdd_Click"></Button>
        <Button Content="선택 삭제" Margin="10" Click="btnDelete_Click"></Button>

        <Label Content="이름" Margin="10" />
        <TextBlock Text="{Binding SelectedChar.Name}" Margin="10"></TextBlock>
        <Label Content="직업:" Margin="10" />
        <TextBlock Text="{Binding SelectedChar.CharClass}" Margin="10"></TextBlock>
        <Label Content="레벨:" Margin="10" />
        <TextBlock Text="{Binding SelectedChar.Level}" Margin="10"></TextBlock>
        <Label Content="Hp:" Margin="10" />
        <TextBlock Text="{Binding SelectedChar.Hp}" Margin="10"></TextBlock>
        <Label Content="Mp:" Margin="10" />
        <TextBlock Text="{Binding SelectedChar.Mp}" Margin="10"></TextBlock>
        <Button Content="레벨업" Margin="10" Click="btnLevelUp_Click"/>
    </StackPanel>
</Window>
