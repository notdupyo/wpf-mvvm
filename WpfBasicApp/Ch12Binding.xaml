<Window x:Class="WpfBasicApp.Ch12Binding"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfBasicApp"
        mc:Ignorable="d"
        Title="Ch12Binding" Height="800" Width="450">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="이름: "></Label>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CharName}"></TextBox>
        
        <Label Grid.Row="1" Grid.Column="0" Content="직업: "></Label>
        <ComboBox Grid.Row="1" Grid.Column="1">
            <ComboBoxItem Content="전사"></ComboBoxItem>
            <ComboBoxItem Content="마법사"></ComboBoxItem>
        </ComboBox>
        <Label Grid.Row="2" Grid.Column="0" Content="레벨: "></Label>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Level}"></TextBox>
        
        <Label Grid.Row="3" Grid.Column="0" Content="HP: "></Label>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Hp}"></TextBox>
        
        <Label Grid.Row="4" Grid.Column="0" Content="MP: "></Label>
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Mp}"></TextBox>

        <Button x:Name="btnRegist" Grid.Row="5" Grid.Column="0" Content="확인" Click="btnRegist_Click"></Button>
        <Button x:Name="btnChange" Grid.Row="5" Grid.Column="1" Content="캐릭터 교체" Click="btnChange_Click"></Button>

        <TextBlock x:Name="tblckResult" Grid.Row="6" Grid.ColumnSpan="2" Text="" />
    </Grid>
</Window>
