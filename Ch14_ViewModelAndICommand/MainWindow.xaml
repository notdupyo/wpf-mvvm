<Window x:Class="Ch14_ViewModelAndICommand.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ch14_ViewModelAndICommand"
        mc:Ignorable="d"
        Title="Command 패턴 예제" Height="450" Width="350">
    <StackPanel Margin="15">
        
        <!--학생 목록-->
        <Label Content="학생 목록:" FontWeight="Bold" />
        <!-- ListBox의 DisplayMemberPath 속성은 ItemsSouce의 객체가 가진 멤버(속성) 중 
             UI에 표시 하고 싶은 속성을 선택하는 컨트롤 속성이다-->
        <ListBox Height="120"
                 ItemsSource="{Binding Students}"
                 DisplayMemberPath="Name" 
                 SelectedItem="{Binding SelectedStudent}" />
        
        <!-- Command 바인딩 : Click 속성이 없음 -->
        <!-- CanExecute가 false면 버튼이 자동으로 비활성화 -->
        <StackPanel Orientation="Horizontal" Margin="0, 10">
            <Button Content="학생 추가"
                    Command="{Binding AddStudentCommand}"
                    Padding="8,4" Margin="0,0,5,0" />
            <Button Content="선택 삭제"
                    Command="{Binding RemoveStudentCommand}"
                    Padding="8,4" />
            <!-- 미선택 시 "선택 삭제"버튼 자동 비활성화 -->
        </StackPanel>        
        
        <!-- 선택한 학생 정보 표시-->
        <Label Content="선택한 학생: "
               FontWeight="Bold"
               Margin="0,10,0,0" />
        <TextBlock Text="{Binding SelectedStudent.Name}" FontSize="14" />
        <TextBlock Text="{Binding SelectedStudent.Score, StringFormat={}{0}점}" />
        <!-- StringFormat: 바인딩 값에 서식 적용, 앞의 빈 {}는 escape 문자임, {0}에 Score 들어감 -->
        
        <!---->

    </StackPanel>
</Window>
